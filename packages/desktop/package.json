{
  "name": "@cbz-tool/desktop",
  "version": "1.2.1",
  "description": "CBZ Tool desktop app",
  "author": "LuzAramburo",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch ../server --ext js --exec electron index.js",
    "package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@cbz-tool/server": "*"
  },
  "devDependencies": {
    "electron": "41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.luzaramburo.cbz-tool",
    "electronVersion": "41.2.1",
    "productName": "CBZ Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.js",
      "node_modules/**",
      "!node_modules/.cache/**",
      "!node_modules/@cbz-tool/server/data/**",
      "!node_modules/@cbz-tool/server/coverage/**",
      "!node_modules/@cbz-tool/server/tests/**",
      "!node_modules/@cbz-tool/server/*.ts"
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false,
      "icon": "../ui/public/favicon.ico"
    }
  }
}

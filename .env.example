# Uncomment and set to override the default (100 MB)
# MAX_FILE_SIZE_MB=100

# Directory for book storage (default: ./data for dev, /app/data in Docker)
# DATA_DIR=./data

# Server port for dev:web and Electron dev mode (default: 3000).
# Production Electron ignores this — it uses a named pipe with no TCP port.
# PORT=3000
